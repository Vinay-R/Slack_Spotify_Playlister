generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SlackConnection {
  id                    String   @id @default(cuid())
  userId                String
  teamId                String
  teamName              String
  /// @deprecated Legacy plaintext column — kept temporarily for backfill migration.
  /// All new writes MUST use accessTokenEncrypted via saveSlackToken().
  accessToken           String   @default("")
  accessTokenEncrypted  String?
  tokenKeyVersion       Int?
  createdAt             DateTime @default(now())
  channels              TrackedChannel[]

  @@unique([userId, teamId])
}

model SpotifyConnection {
  id                     String   @id @default(cuid())
  userId                 String
  spotifyUserId          String
  displayName            String
  /// @deprecated Legacy plaintext — kept temporarily for backfill. Use accessTokenEncrypted.
  accessToken            String   @default("")
  /// @deprecated Legacy plaintext — kept temporarily for backfill. Use refreshTokenEncrypted.
  refreshToken           String   @default("")
  accessTokenEncrypted   String?
  refreshTokenEncrypted  String?
  tokenKeyVersion        Int?
  expiresAt              DateTime
  createdAt              DateTime @default(now())

  @@unique([userId, spotifyUserId])
}

model TrackedChannel {
  id                 String   @id @default(cuid())
  userId             String
  channelId          String
  channelName        String
  slackConnectionId  String
  slackConnection    SlackConnection @relation(fields: [slackConnectionId], references: [id], onDelete: Cascade)
  spotifyPlaylistId  String?
  spotifyPlaylistUrl String?
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  tracks             PlaylistTrack[]

  @@unique([userId, channelId])
  @@index([slackConnectionId])
}

model PlaylistTrack {
  id               String   @id @default(cuid())
  trackUri         String
  channelId        String
  trackedChannel   TrackedChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  slackMessageTs   String?
  addedAt          DateTime @default(now())

  @@unique([trackUri, channelId])
  @@index([channelId])
}
