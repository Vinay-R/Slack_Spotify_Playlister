generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SlackConnection {
  id          String   @id @default(cuid())
  teamId      String   @unique
  teamName    String
  accessToken String
  createdAt   DateTime @default(now())
  channels    TrackedChannel[]
}

model SpotifyConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  displayName  String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model TrackedChannel {
  id                 String   @id @default(cuid())
  channelId          String   @unique
  channelName        String
  slackConnectionId  String
  slackConnection    SlackConnection @relation(fields: [slackConnectionId], references: [id], onDelete: Cascade)
  spotifyPlaylistId  String?
  spotifyPlaylistUrl String?
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  tracks             PlaylistTrack[]
}

model PlaylistTrack {
  id               String   @id @default(cuid())
  trackUri         String
  channelId        String
  trackedChannel   TrackedChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  slackMessageTs   String?
  addedAt          DateTime @default(now())

  @@unique([trackUri, channelId])
}
